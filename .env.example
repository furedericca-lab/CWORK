# Core runtime
HOST=0.0.0.0
PORT=8787
API_AUTH_TOKEN=dev-token

# Dify provider (Dify-only policy)
DIFY_API_KEY=replace_me

# Optional runtime capability switches
CWORK_RUNTIME_MODE=none
CWORK_SANDBOX_ENABLED=false
CWORK_SEARCH_PROVIDER=default

# Optional tool/plugin policy controls
# CWORK_ALLOW_TOOLS=tool.echo,web.search,kb.retrieve
# CWORK_DENY_TOOLS=
# CWORK_DENY_PLUGIN_CAPS=

# Web runtime
VITE_API_BASE=/api/v1
