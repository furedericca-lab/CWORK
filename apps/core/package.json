{
  "name": "@cwork/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:security": "vitest run test/security",
    "e2e": "vitest run test/e2e",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "perf:smoke": "tsx scripts/perf-smoke.ts",
    "reliability:smoke": "tsx scripts/reliability-smoke.ts"
  },
  "dependencies": {
    "@cwork/shared": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "fastify": "^5.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "vitest": "^4.0.18"
  }
}
